+/*
+ * Go wrapper for wolfssh's wolfSSH_ReadKey_buffer entry point in
+ * src/ssh.c. wolfssh.go covers the analogous *public* key path
+ * (WolfSSH_ReadPublicKey_buffer); this file ships the private
+ * key path so callers loading PEM-armored OpenSSH PRIVATE KEY
+ * blocks (or PKCS-armored DER) can hand the bytes off to
+ * wolfssh's identifier without re-deriving the base64 decode +
+ * algorithm detection in Go.
+ *
+ * The cgo preamble repeats the wolfssh include directive
+ * because every Go file using `import "C"` gets its own
+ * preamble; the package's #cgo CFLAGS / LDFLAGS live in
+ * wolfssh.go and apply package-wide.
+ */
+package wolfssh
+
+// #include <wolfssh/ssh.h>
+// #include <stdlib.h>
+import "C"
+
+import (
+    "unsafe"
+)
+
+/*
+ * WolfSSH_ReadKey_buffer parses an SSH PRIVATE key from a
+ * caller-provided buffer using wolfssh's wolfSSH_ReadKey_buffer
+ * / DoOpenSshKey / DoPemKey machinery in src/ssh.c. The input
+ * is the raw bytes of a PEM blob ("-----BEGIN OPENSSH PRIVATE
+ * KEY-----..." for FORMAT_OPENSSH or a PKCS-style "-----BEGIN
+ * ... PRIVATE KEY-----" for FORMAT_PEM).
+ *
+ * Returns:
+ *   out  - the parsed binary key payload. For FORMAT_OPENSSH
+ *          this is the post-base64 binary OpenSSH PRIVATE KEY
+ *          blob (the "openssh-key-v1\0..." structured payload
+ *          that ParseOpenSshPrivateKey in openssh_privkey.go
+ *          walks). For FORMAT_PEM this is the DER-encoded
+ *          private key.
+ *   algo - the algorithm name wolfssh identified (e.g.
+ *          "ssh-ed25519").
+ *   rc   - wolfssh return code; 0 on success. Note: when the
+ *          linked wolfSSL was not built with HAVE_ED25519_KEY_-
+ *          IMPORT / _EXPORT / WOLFSSL_ED25519_STREAMING_VERIFY,
+ *          wolfssh's GetOpenSshKey returns WS_UNIMPLEMENTED_E
+ *          (-1017) for ed25519 OpenSSH PRIVATE KEY blobs. The
+ *          pure-Go ParseOpenSshPrivateKeyPEM path in
+ *          openssh_privkey.go covers that gap until the build
+ *          profile picks up the extra ed25519 flags.
+ *
+ * The wolfssh C side WMALLOC's the output buffer; this wrapper
+ * copies the bytes into a Go []byte and releases the C
+ * allocation before returning, so callers do not need to worry
+ * about lifetimes. algo points into wolfssh's static IdToName
+ * string table on the C side, but the wrapper returns it as a
+ * Go string built via C.GoBytes-style copy, so it survives the
+ * wrapper's lifetime independent of wolfssh's tables.
+ */
+func WolfSSH_ReadKey_buffer(in []byte,
+    format int) (out []byte, algo string, rc int) {
+    if len(in) == 0 {
+        return nil, "", -1
+    }
+    var cOut *C.byte
+    var cOutSz C.word32
+    var cOutType *C.byte
+    var cOutTypeSz C.word32
+
+    rcCInt := C.wolfSSH_ReadKey_buffer(
+        (*C.byte)(unsafe.Pointer(&in[0])),
+        C.word32(len(in)),
+        C.int(format),
+        &cOut, &cOutSz,
+        (**C.byte)(unsafe.Pointer(&cOutType)),
+        &cOutTypeSz,
+        nil)
+    if rcCInt != 0 {
+        if cOut != nil {
+            C.free(unsafe.Pointer(cOut))
+        }
+        /* cOutType points into wolfssh's static IdToName
+         * table - never free it. */
+        return nil, "", int(rcCInt)
+    }
+    defer C.free(unsafe.Pointer(cOut))
+    out = C.GoBytes(unsafe.Pointer(cOut), C.int(cOutSz))
+    algo = string(C.GoBytes(unsafe.Pointer(cOutType),
+        C.int(cOutTypeSz)))
+    return out, algo, 0
+}
