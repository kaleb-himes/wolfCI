+ * along with this program; if not, write to the Free Software
+ * Foundation, Inc., 51 Franklin Street, Fifth Floor, Boston, MA
+ * 02110-1335, USA
+ */
+
+/*
+ * Exercises the OpenSSH PRIVATE KEY encoder + decoder + the
+ * wolfSSH_ReadKey_buffer Go wrapper. Round-trips an Ed25519
+ * keypair through both paths and verifies the decoded seed /
+ * pubkey match the originals.
+ */
+package wolfssh_test
+
+import (
+    "bytes"
+    "testing"
+
+    gowolf "github.com/wolfssl/go-wolfssl"
+    "github.com/wolfssl/go-wolfssl/wolfssh"
+)
+
+/*
+ * TestOpenSshPrivateKey_Ed25519_RoundTrip generates an Ed25519
+ * key via wolfCrypt, encodes it as an OPENSSH PRIVATE KEY PEM,
+ * then walks the PEM with both ParseOpenSshPrivateKeyPEM (pure
+ * Go) and WolfSSH_ReadKey_buffer + ParseOpenSshPrivateKey
+ * (wolfssh-backed PEM unwrap, then Go structural walk). Both
+ * paths must yield the same seed + pubkey bytes.
+ */
+func TestOpenSshPrivateKey_Ed25519_RoundTrip(t *testing.T) {
+    seed, pub := newEd25519KeyForPEM(t)
+    pem, err := wolfssh.EncodeOpenSshPrivateKeyEd25519PEM(
+        seed, pub, "wolfci-bot@localhost", 0xdeadbeef)
+    if err != nil {
+        t.Fatalf("EncodeOpenSshPrivateKeyEd25519PEM: %v", err)
+    }
+
+    /* (1) Pure-Go parse path. */
+    parsed, err := wolfssh.ParseOpenSshPrivateKeyPEM(pem)
+    if err != nil {
+        t.Fatalf("ParseOpenSshPrivateKeyPEM: %v", err)
+    }
+    if parsed.Algorithm != wolfssh.AlgSSHEd25519 {
+        t.Errorf("Algorithm = %q", parsed.Algorithm)
+    }
+    if parsed.Comment != "wolfci-bot@localhost" {
+        t.Errorf("Comment = %q", parsed.Comment)
+    }
+    if !bytes.Equal(parsed.Ed25519Seed, seed) {
+        t.Errorf("Ed25519Seed round-trip mismatch")
+    }
+    if !bytes.Equal(parsed.Ed25519Pub, pub) {
+        t.Errorf("Ed25519Pub round-trip mismatch")
+    }
+    if !bytes.Equal(parsed.KeyBlob,
+        wolfssh.EncodeSSHString(pub)) {
+        t.Errorf("KeyBlob = % x, want EncodeSSHString(pub)",
+            parsed.KeyBlob)
+    }
+
+    /* (2) wolfssh-backed PEM unwrap then Go structural walk.
+     * The C-side DoOpenSshKey path only recognises Ed25519
+     * when the linked wolfSSL was built with the streaming
+     * verify + key-import + key-export ed25519 features
+     * (HAVE_ED25519_KEY_IMPORT / _EXPORT /
+     * WOLFSSL_ED25519_STREAMING_VERIFY). The current
+     * wolfCI wolfSSL profile enables --enable-ed25519 but not
+     * the stream/key-import variants, so wolfssh's
+     * GetOpenSshKey falls through to WS_UNIMPLEMENTED_E (-1017).
+     * The wrapper itself is still useful for other algorithms
+     * / formats; skip the round-trip half of this test when
+     * the C side returns WS_UNIMPLEMENTED_E and surface the
+     * skip reason so future builds (with the extra ed25519
+     * flags) automatically promote the gate. */
+    raw, algo, rc := wolfssh.WolfSSH_ReadKey_buffer(pem,
+        wolfssh.FORMAT_OPENSSH)
+    if rc == -1017 {
+        t.Skipf("WolfSSH_ReadKey_buffer returned " +
+            "WS_UNIMPLEMENTED_E for ed25519 OPENSSH key; " +
+            "rebuild wolfSSL with --enable-ed25519-stream " +
+            "and HAVE_ED25519_KEY_EXPORT to promote this " +
+            "half of the test")
+        return
+    }
+    if rc != 0 {
+        t.Fatalf("WolfSSH_ReadKey_buffer rc=%d", rc)
+    }
+    if algo != wolfssh.AlgSSHEd25519 {
+        t.Errorf("wolfssh wrapper algo = %q", algo)
+    }
+    walked, err := wolfssh.ParseOpenSshPrivateKey(raw)
+    if err != nil {
+        t.Fatalf("ParseOpenSshPrivateKey: %v", err)
+    }
+    if !bytes.Equal(walked.Ed25519Seed, seed) {
+        t.Errorf("wolfssh-wrapper Ed25519Seed mismatch")
+    }
+    if !bytes.Equal(walked.Ed25519Pub, pub) {
+        t.Errorf("wolfssh-wrapper Ed25519Pub mismatch")
+    }
+}
+
+/*
+ * TestOpenSshPrivateKey_RejectsEncrypted locks in the
+ * actionable error path: a key with a non-"none" cipher must
+ * surface as a clean error, not a crash.
+ */
+func TestOpenSshPrivateKey_RejectsEncrypted(t *testing.T) {
+    /* Build a hand-crafted blob with ciphername = "aes256-ctr". */
+    var buf bytes.Buffer
+    buf.WriteString("openssh-key-v1\x00")
+    buf.Write(wolfssh.EncodeSSHString([]byte("aes256-ctr")))
+    buf.Write(wolfssh.EncodeSSHString([]byte("bcrypt")))
+    buf.Write(wolfssh.EncodeSSHString([]byte("opts")))
+    buf.Write([]byte{0, 0, 0, 1})
+    buf.Write(wolfssh.EncodeSSHString(
+        wolfssh.EncodeSSHString([]byte("ssh-ed25519"))))
+    buf.Write(wolfssh.EncodeSSHString([]byte("garbage")))
+    _, err := wolfssh.ParseOpenSshPrivateKey(buf.Bytes())
+    if err == nil {
+        t.Fatalf("expected error for ciphername != none")
+    }
+}
+
+/*
+ * newEd25519KeyForPEM mints a fresh Ed25519 keypair via the
+ * root go-wolfssl package's wolfCrypt wrappers. The shape
+ * matches what 18.20's sshagent step will see at runtime: a
+ * 32-byte seed plus a 32-byte public key.
+ */
+func newEd25519KeyForPEM(t *testing.T) (seed, pub []byte) {
+    t.Helper()
+    var rng gowolf.WC_RNG
+    if rc := gowolf.Wc_InitRng(&rng); rc != 0 {
+        t.Fatalf("Wc_InitRng: %d", rc)
+    }
+    t.Cleanup(func() { gowolf.Wc_FreeRng(&rng) })
+
+    var key gowolf.Ed25519_key
+    if rc := gowolf.Wc_ed25519_init(&key); rc != 0 {
+        t.Fatalf("Wc_ed25519_init: %d", rc)
+    }
+    t.Cleanup(func() { gowolf.Wc_ed25519_free(&key) })
+
+    if rc := gowolf.Wc_ed25519_make_key(&rng, 32, &key); rc != 0 {
+        t.Fatalf("Wc_ed25519_make_key: %d", rc)
+    }
+    pub = make([]byte, 32)
+    pubLen := 32
+    if rc := gowolf.Wc_ed25519_export_public(&key, pub,
+        &pubLen); rc != 0 {
+        t.Fatalf("Wc_ed25519_export_public: %d", rc)
+    }
+    seed = make([]byte, 32)
+    seedLen := 32
+    if rc := gowolf.Wc_ed25519_export_private_only(&key, seed,
+        &seedLen); rc != 0 {
+        t.Fatalf("Wc_ed25519_export_private_only: %d", rc)
+    }
+    return seed, pub
+}
