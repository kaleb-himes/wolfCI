+++ b/wolfssh/agent.go
@@ -0,0 +1,323 @@
+/* agent.go
+ *
+ * Copyright (C) 2006-2026 wolfSSL Inc.
+ *
+ * This file is part of wolfSSL.
+ *
+ * wolfSSL is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License as published
+ * by the Free Software Foundation; either version 2 of the License,
+ * or (at your option) any later version.
+ *
+ * wolfSSL is distributed in the hope that it will be useful, but
+ * WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public License
+ * along with this program; if not, write to the Free Software
+ * Foundation, Inc., 51 Franklin Street, Fifth Floor, Boston, MA
+ * 02110-1335, USA
+ */
+
+/*
+ * Pure-Go SSH agent-protocol helpers. No CGO; the file is usable
+ * without linking libwolfssh.a. The agent uses the wire-format
+ * helpers from sshwire.go (ReadSSHString / EncodeSSHString) for
+ * framing and an Identity-supplied signing closure for the actual
+ * cryptography, so callers wire up whichever wolfCrypt primitive
+ * matches the identity's algorithm (Wc_ed25519_sign_msg for
+ * ssh-ed25519 keys, Wc_SignatureGenerate for RSA / ECDSA, etc.).
+ *
+ * Why these live in the wolfssh sub-package: this is the protocol
+ * wolfssh's C-side agent.c (compiled with WOLFSSH_AGENT) speaks.
+ * Mirroring the message IDs and framing here gives callers a Go
+ * agent that wire-interoperates with wolfssh-built clients without
+ * pulling libwolfssh.a's agent state machine into Go. When
+ * wolfssh upstream exposes its agent state machine through a
+ * stable C ABI the Go wrappers can switch to it and this file
+ * shrinks to a thin CGO bridge.
+ *
+ * Supported message types (matching wolfssh/agent.h):
+ *
+ *   MSGID_AGENT_REQUEST_IDENTITIES (11) -> IDENTITIES_ANSWER (12)
+ *   MSGID_AGENT_SIGN_REQUEST       (13) -> SIGN_RESPONSE      (14)
+ *
+ * Other message types (ADD_IDENTITY, REMOVE_IDENTITY, LOCK,
+ * UNLOCK, EXTENSION) get SSH_AGENT_FAILURE so a misbehaving
+ * client cannot hang the agent. Promoting any of those to real
+ * support is one switch arm plus a wire decoder.
+ */
+package wolfssh
+
+import (
+    "bytes"
+    "encoding/binary"
+    "errors"
+    "sync"
+)
+
+/*
+ * SSH agent-protocol message IDs. Values mirror the
+ * MSGID_AGENT_* enum in third_party/wolfssh/wolfssh/agent.h
+ * verbatim so a wire dump from one stack drops in on the
+ * other.
+ */
+const (
+    AgentMsgFailure              = 5
+    AgentMsgSuccess              = 6
+    AgentMsgRequestIdentities    = 11
+    AgentMsgIdentitiesAnswer     = 12
+    AgentMsgSignRequest          = 13
+    AgentMsgSignResponse         = 14
+    AgentMsgAddIdentity          = 17
+    AgentMsgRemoveIdentity       = 18
+    AgentMsgRemoveAllIdentities  = 19
+)
+
+/*
+ * AgentSigner is the per-identity signing primitive. Callers
+ * implement this with whichever wolfCrypt routine matches the
+ * identity's algorithm; the agent itself stays algorithm-
+ * agnostic. challenge is the SSH session-id bytes the client
+ * wants signed; the returned signature is the algorithm's raw
+ * signature payload (64 bytes for ed25519, the DER-encoded
+ * (r, s) sequence for ECDSA, etc.). The caller decides which
+ * encoding it returns; SignResponse wraps it in the
+ * "string(algo) || string(sig)" envelope on the way out.
+ */
+type AgentSigner func(challenge []byte) ([]byte, error)
+
+/*
+ * AgentIdentity is one entry in the agent's identity table.
+ *
+ *   KeyBlob   - the SSH wire-format public key payload
+ *               (algorithm-specific body after the algo
+ *               string; ParseSSHWirePublicKey is the inverse).
+ *   Algorithm - the algorithm name string (AlgSSHEd25519,
+ *               AlgECDSAP256SHA256, AlgRSASHA256, ...).
+ *   Comment   - the human-readable comment the agent reports
+ *               in IDENTITIES_ANSWER; usually "user@host".
+ *   Sign      - the signing primitive (see AgentSigner).
+ *
+ * KeyBlob is the part that comes BETWEEN the leading
+ * length-prefixed algorithm string and the rest in the SSH
+ * authorized_keys wire format. The IDENTITIES_ANSWER message
+ * wraps this and the algorithm string together into a single
+ * length-prefixed blob, matching the on-wire shape OpenSSH
+ * ssh-add produces.
+ */
+type AgentIdentity struct {
+    KeyBlob   []byte
+    Algorithm string
+    Comment   string
+    Sign      AgentSigner
+}
+
+/*
+ * Agent is an in-memory SSH agent. Identities are addressed by
+ * their wire-format public-key blob (algo string + key body),
+ * matching how the agent protocol's SIGN_REQUEST routes to a
+ * key. The Agent is goroutine-safe so wolfCI's parallel test
+ * runners can share one instance across stages without
+ * surprises.
+ */
+type Agent struct {
+    mu         sync.RWMutex
+    identities []AgentIdentity
+}
+
+/*
+ * NewAgent returns an empty agent ready to receive identities.
+ */
+func NewAgent() *Agent {
+    return &Agent{}
+}
+
+/*
+ * AddIdentity appends id to the agent's table. Duplicate
+ * KeyBlobs are not deduped here - upstream agents accept
+ * duplicates and let the operator decide; we match that.
+ */
+func (a *Agent) AddIdentity(id AgentIdentity) {
+    a.mu.Lock()
+    defer a.mu.Unlock()
+    a.identities = append(a.identities, id)
+}
+
+/*
+ * Identities returns a defensive copy of the agent's identity
+ * table so callers can iterate without racing AddIdentity.
+ */
+func (a *Agent) Identities() []AgentIdentity {
+    a.mu.RLock()
+    defer a.mu.RUnlock()
+    out := make([]AgentIdentity, len(a.identities))
+    copy(out, a.identities)
+    return out
+}
+
+/*
+ * RemoveAll clears the identity table.
+ */
+func (a *Agent) RemoveAll() {
+    a.mu.Lock()
+    defer a.mu.Unlock()
+    a.identities = nil
+}
+
+/*
+ * HandleMessage processes one agent-protocol request and
+ * returns the response body. Both slices are the message
+ * BODY (no uint32 length prefix); callers using
+ * HandleFramedMessage get the framing layer added for them.
+ *
+ * Unrecognised or malformed requests resolve to a single
+ * AgentMsgFailure byte so the wire client doesn't hang.
+ * err is non-nil only on internal infrastructure failures
+ * the caller cannot recover from; protocol-level errors
+ * (bad keyblob, unknown identity) surface via AgentMsgFailure.
+ */
+func (a *Agent) HandleMessage(req []byte) ([]byte, error) {
+    if len(req) < 1 {
+        return agentFailure(), nil
+    }
+    msgID := req[0]
+    body := req[1:]
+    switch msgID {
+    case AgentMsgRequestIdentities:
+        return a.handleListIdentities(), nil
+    case AgentMsgSignRequest:
+        return a.handleSignRequest(body)
+    }
+    return agentFailure(), nil
+}
+
+/*
+ * HandleFramedMessage handles a wire-framed agent message.
+ * req is uint32-length-prefixed; the response is too. Useful
+ * for callers reading from a net.Conn that frames every
+ * message with a 4-byte big-endian length.
+ */
+func (a *Agent) HandleFramedMessage(req []byte) ([]byte, error) {
+    if len(req) < 4 {
+        return nil, errors.New(
+            "wolfssh: agent: framed message shorter than 4 " +
+                "bytes")
+    }
+    length := binary.BigEndian.Uint32(req[:4])
+    if uint32(len(req)-4) < length {
+        return nil, errors.New(
+            "wolfssh: agent: framed message length exceeds " +
+                "buffer")
+    }
+    body, err := a.HandleMessage(req[4 : 4+length])
+    if err != nil {
+        return nil, err
+    }
+    out := make([]byte, 4+len(body))
+    binary.BigEndian.PutUint32(out[:4], uint32(len(body)))
+    copy(out[4:], body)
+    return out, nil
+}
+
+/*
+ * agentFailure returns the canonical single-byte failure
+ * response the agent protocol uses for any unrecognised or
+ * malformed request.
+ */
+func agentFailure() []byte {
+    return []byte{AgentMsgFailure}
+}
+
+/*
+ * handleListIdentities builds an IDENTITIES_ANSWER response.
+ * Wire shape (RFC-draft-miller-ssh-agent section 4.4):
+ *
+ *   byte    SSH_AGENT_IDENTITIES_ANSWER
+ *   uint32  num_keys
+ *   repeated num_keys times:
+ *     string key_blob
+ *     string comment
+ *
+ * key_blob is the full SSH wire-format public key, including
+ * the leading length-prefixed algorithm string AND the body.
+ * AgentIdentity.KeyBlob stores only the algorithm-specific
+ * body, so we emit "string(algo) || body" composed.
+ */
+func (a *Agent) handleListIdentities() []byte {
+    ids := a.Identities()
+    var out bytes.Buffer
+    out.WriteByte(AgentMsgIdentitiesAnswer)
+    var num [4]byte
+    binary.BigEndian.PutUint32(num[:], uint32(len(ids)))
+    out.Write(num[:])
+    for _, id := range ids {
+        out.Write(EncodeSSHString(buildKeyBlob(id)))
+        out.Write(EncodeSSHString([]byte(id.Comment)))
+    }
+    return out.Bytes()
+}
+
+/*
+ * handleSignRequest decodes a SIGN_REQUEST and dispatches to
+ * the matching identity. Wire shape:
+ *
+ *   byte    SSH_AGENTC_SIGN_REQUEST
+ *   string  key_blob          (same shape as IDENTITIES_ANSWER)
+ *   string  data              (challenge to sign)
+ *   uint32  flags             (ignored; we always sign with
+ *                              the identity's default algorithm)
+ *
+ * Response on success:
+ *
+ *   byte    SSH_AGENT_SIGN_RESPONSE
+ *   string  signature_blob    (string(algo) || string(sig))
+ *
+ * Response on failure: single AgentMsgFailure byte.
+ */
+func (a *Agent) handleSignRequest(body []byte) ([]byte, error) {
+    keyBlob, rest, err := ReadSSHString(body)
+    if err != nil {
+        return agentFailure(), nil
+    }
+    challenge, _, err := ReadSSHString(rest)
+    if err != nil {
+        return agentFailure(), nil
+    }
+    /* flags uint32 follows but is ignored for 18.19; the
+     * subset we ship signs with the identity's default
+     * algorithm. */
+    ids := a.Identities()
+    for _, id := range ids {
+        if !bytes.Equal(buildKeyBlob(id), keyBlob) {
+            continue
+        }
+        sig, sigErr := id.Sign(challenge)
+        if sigErr != nil {
+            return agentFailure(), nil
+        }
+        inner := bytes.Buffer{}
+        inner.Write(EncodeSSHString([]byte(id.Algorithm)))
+        inner.Write(EncodeSSHString(sig))
+        var out bytes.Buffer
+        out.WriteByte(AgentMsgSignResponse)
+        out.Write(EncodeSSHString(inner.Bytes()))
+        return out.Bytes(), nil
+    }
+    return agentFailure(), nil
+}
+
+/*
+ * buildKeyBlob composes the IDENTITIES_ANSWER / SIGN_REQUEST
+ * key-blob payload from an AgentIdentity: the algorithm name
+ * as a length-prefixed string followed by the identity's
+ * algorithm-specific body. This is the same shape the
+ * authorized_keys base64 payload decodes into.
+ */
+func buildKeyBlob(id AgentIdentity) []byte {
+    var out bytes.Buffer
+    out.Write(EncodeSSHString([]byte(id.Algorithm)))
+    out.Write(id.KeyBlob)
+    return out.Bytes()
+}
