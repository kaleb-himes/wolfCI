+/* agent_test.go
+ *
+ * Copyright (C) 2006-2026 wolfSSL Inc.
+ *
+ * This file is part of wolfSSL.
+ *
+ * wolfSSL is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License as published
+ * by the Free Software Foundation; either version 2 of the License,
+ * or (at your option) any later version.
+ *
+ * wolfSSL is distributed in the hope that it will be useful, but
+ * WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public License
+ * along with this program; if not, write to the Free Software
+ * Foundation, Inc., 51 Franklin Street, Fifth Floor, Boston, MA
+ * 02110-1335, USA
+ */
+
+/*
+ * Exercises the agent.go SSH-agent wire surface end to end:
+ * mint a fresh Ed25519 keypair via the wolfCrypt wrappers in
+ * the root go-wolfssl package, register it on a wolfssh Agent,
+ * round-trip an SSH_AGENTC_REQUEST_IDENTITIES, then ask the
+ * same agent to sign a challenge and verify the signature
+ * with wolfCrypt's Ed25519 verifier. The whole protocol path
+ * (wire framing, identity matching, signature envelope) goes
+ * through the public surface of this package; the test never
+ * pokes private state.
+ */
+package wolfssh_test
+
+import (
+    "bytes"
+    "encoding/binary"
+    "testing"
+
+    gowolf "github.com/wolfssl/go-wolfssl"
+    "github.com/wolfssl/go-wolfssl/wolfssh"
+)
+
+/*
+ * TestAgent_AddListSign is the PLAN.md 18.19 gate. Mints an
+ * Ed25519 identity, lists it through the agent protocol, then
+ * signs a challenge through the same protocol and verifies
+ * the resulting signature against the identity's public key.
+ */
+func TestAgent_AddListSign(t *testing.T) {
+    pub, sign, verify := newEd25519Identity(t)
+    defer verify.close()
+
+    /* Build an AgentIdentity. KeyBlob is the SSH wire body for
+     * ssh-ed25519: one length-prefixed string holding the 32
+     * raw pubkey bytes. */
+    keyBlob := encodeString(pub)
+    agent := wolfssh.NewAgent()
+    agent.AddIdentity(wolfssh.AgentIdentity{
+        KeyBlob:   keyBlob,
+        Algorithm: wolfssh.AlgSSHEd25519,
+        Comment:   "wolfci-test@localhost",
+        Sign:      sign,
+    })
+
+    /* --- list identities round trip ----------------------- */
+
+    listReq := []byte{wolfssh.AgentMsgRequestIdentities}
+    listResp, err := agent.HandleMessage(listReq)
+    if err != nil {
+        t.Fatalf("HandleMessage(list): %v", err)
+    }
+    if len(listResp) < 5 ||
+        listResp[0] != wolfssh.AgentMsgIdentitiesAnswer {
+        t.Fatalf("list response wrong msgID/short: %v",
+            listResp)
+    }
+    numKeys := binary.BigEndian.Uint32(listResp[1:5])
+    if numKeys != 1 {
+        t.Fatalf("list reported %d keys, want 1", numKeys)
+    }
+    body := listResp[5:]
+    gotBlob, rest, err := wolfssh.ReadSSHString(body)
+    if err != nil {
+        t.Fatalf("read keyblob: %v", err)
+    }
+    gotComment, _, err := wolfssh.ReadSSHString(rest)
+    if err != nil {
+        t.Fatalf("read comment: %v", err)
+    }
+    /* The reported blob is "string(algo) || body". Confirm
+     * both halves match what we registered. */
+    algo, blobBody, err := wolfssh.ReadSSHString(gotBlob)
+    if err != nil {
+        t.Fatalf("parse keyblob: %v", err)
+    }
+    if string(algo) != wolfssh.AlgSSHEd25519 {
+        t.Errorf("algo = %q, want ssh-ed25519", string(algo))
+    }
+    if !bytes.Equal(blobBody, keyBlob) {
+        t.Errorf("blob body mismatch")
+    }
+    if string(gotComment) != "wolfci-test@localhost" {
+        t.Errorf("comment = %q", string(gotComment))
+    }
+
+    /* --- sign round trip --------------------------------- */
+
+    challenge := []byte("wolfci-agent-test-challenge-bytes")
+    signReq := buildSignRequest(gotBlob, challenge)
+    signResp, err := agent.HandleMessage(signReq)
+    if err != nil {
+        t.Fatalf("HandleMessage(sign): %v", err)
+    }
+    if len(signResp) < 1 ||
+        signResp[0] != wolfssh.AgentMsgSignResponse {
+        t.Fatalf("sign response wrong msgID: %v",
+            signResp[:min(8, len(signResp))])
+    }
+    sigBlob, _, err := wolfssh.ReadSSHString(signResp[1:])
+    if err != nil {
+        t.Fatalf("read sig blob: %v", err)
+    }
+    sigAlgo, sigInner, err := wolfssh.ReadSSHString(sigBlob)
+    if err != nil {
+        t.Fatalf("parse sig blob: %v", err)
+    }
+    if string(sigAlgo) != wolfssh.AlgSSHEd25519 {
+        t.Errorf("sig algo = %q", string(sigAlgo))
+    }
+    sigBytes, _, err := wolfssh.ReadSSHString(sigInner)
+    if err != nil {
+        t.Fatalf("parse sig bytes: %v", err)
+    }
+    if len(sigBytes) != 64 {
+        t.Errorf("ed25519 sig is %d bytes, want 64",
+            len(sigBytes))
+    }
+    if !verify.verify(challenge, sigBytes) {
+        t.Errorf("signature did not verify against the "+
+            "registered identity")
+    }
+}
+
+/*
+ * TestAgent_SignRequestUnknownKeyFails locks in the failure
+ * path: a SIGN_REQUEST for a key the agent doesn't hold
+ * returns AgentMsgFailure rather than crashing or silently
+ * signing.
+ */
+func TestAgent_SignRequestUnknownKeyFails(t *testing.T) {
+    agent := wolfssh.NewAgent()
+    bogusBlob := encodeString(make([]byte, 32))
+    /* Wrap "ssh-ed25519" || bogusBlob to look like a real
+     * keyblob the SIGN_REQUEST would carry. */
+    fullBlob := append(
+        encodeString([]byte(wolfssh.AlgSSHEd25519)),
+        bogusBlob...)
+    req := buildSignRequest(fullBlob, []byte("data"))
+    resp, err := agent.HandleMessage(req)
+    if err != nil {
+        t.Fatalf("HandleMessage: %v", err)
+    }
+    if len(resp) != 1 || resp[0] != wolfssh.AgentMsgFailure {
+        t.Errorf("resp = %v, want single AgentMsgFailure "+
+            "byte", resp)
+    }
+}
+
+/*
+ * TestAgent_HandleFramedMessage_RoundTrip exercises the
+ * uint32-length-prefixed convenience entry point against the
+ * empty-list case: it should produce IDENTITIES_ANSWER with
+ * 0 keys, fully framed.
+ */
+func TestAgent_HandleFramedMessage_RoundTrip(t *testing.T) {
+    agent := wolfssh.NewAgent()
+    inner := []byte{wolfssh.AgentMsgRequestIdentities}
+    framed := append([]byte{0, 0, 0, byte(len(inner))}, inner...)
+    resp, err := agent.HandleFramedMessage(framed)
+    if err != nil {
+        t.Fatalf("HandleFramedMessage: %v", err)
+    }
+    if len(resp) < 9 {
+        t.Fatalf("framed resp too short: %v", resp)
+    }
+    length := binary.BigEndian.Uint32(resp[:4])
+    if int(length) != len(resp)-4 {
+        t.Errorf("framed length %d, body %d bytes",
+            length, len(resp)-4)
+    }
+    if resp[4] != wolfssh.AgentMsgIdentitiesAnswer {
+        t.Errorf("body msgID = %d, want IDENTITIES_ANSWER",
+            resp[4])
+    }
+    if num := binary.BigEndian.Uint32(resp[5:9]); num != 0 {
+        t.Errorf("framed empty-list reported %d keys", num)
+    }
+}
+
+/* ----- helpers --------------------------------------------- */
+
+/*
+ * encodeString wraps EncodeSSHString for one-shot inline use
+ * in test fixtures. Kept here so the test reads top to bottom
+ * without each step's serialisation noise.
+ */
+func encodeString(b []byte) []byte {
+    return wolfssh.EncodeSSHString(b)
+}
+
+/*
+ * buildSignRequest builds a wire SIGN_REQUEST body (no length
+ * prefix - HandleMessage takes the unframed payload).
+ */
+func buildSignRequest(keyBlob, challenge []byte) []byte {
+    var buf bytes.Buffer
+    buf.WriteByte(wolfssh.AgentMsgSignRequest)
+    buf.Write(wolfssh.EncodeSSHString(keyBlob))
+    buf.Write(wolfssh.EncodeSSHString(challenge))
+    /* flags */
+    var flags [4]byte
+    buf.Write(flags[:])
+    return buf.Bytes()
+}
+
+/*
+ * ed25519Verifier wraps a wolfCrypt Ed25519 key configured
+ * for verification. close() must be called to release the
+ * underlying wolfCrypt state.
+ */
+type ed25519Verifier struct {
+    key *gowolf.Ed25519_key
+}
+
+func (v *ed25519Verifier) verify(msg, sig []byte) bool {
+    var res int
+    rc := gowolf.Wc_ed25519_verify_msg(sig, len(sig),
+        msg, len(msg), &res, v.key)
+    return rc == 0 && res == 1
+}
+
+func (v *ed25519Verifier) close() {
+    if v.key != nil {
+        gowolf.Wc_ed25519_free(v.key)
+    }
+}
+
+/*
+ * newEd25519Identity mints a fresh Ed25519 keypair via
+ * wolfCrypt, returns the public-key bytes (32 raw bytes), a
+ * signing closure that uses Wc_ed25519_sign_msg on the
+ * private side, and a verifier holding the public key for
+ * the test to verify the agent's signatures with.
+ *
+ * The signing closure owns its own ed25519_key state so the
+ * test's verifier is fully separable; the cleanup t.Cleanup
+ * call below releases both.
+ */
+func newEd25519Identity(t *testing.T) ([]byte,
+    wolfssh.AgentSigner, *ed25519Verifier) {
+    t.Helper()
+    var rng gowolf.WC_RNG
+    if rc := gowolf.Wc_InitRng(&rng); rc != 0 {
+        t.Fatalf("Wc_InitRng: %d", rc)
+    }
+    t.Cleanup(func() { gowolf.Wc_FreeRng(&rng) })
+
+    var signerKey gowolf.Ed25519_key
+    if rc := gowolf.Wc_ed25519_init(&signerKey); rc != 0 {
+        t.Fatalf("Wc_ed25519_init (signer): %d", rc)
+    }
+    t.Cleanup(func() { gowolf.Wc_ed25519_free(&signerKey) })
+
+    if rc := gowolf.Wc_ed25519_make_key(&rng, 32,
+        &signerKey); rc != 0 {
+        t.Fatalf("Wc_ed25519_make_key: %d", rc)
+    }
+    pub := make([]byte, 32)
+    pubLen := 32
+    if rc := gowolf.Wc_ed25519_export_public(&signerKey, pub,
+        &pubLen); rc != 0 {
+        t.Fatalf("Wc_ed25519_export_public: %d", rc)
+    }
+    if pubLen != 32 {
+        t.Fatalf("ed25519 export pubLen = %d, want 32", pubLen)
+    }
+
+    /* Re-import the public bytes into a fresh key for the
+     * verifier - exercises the same wire shape an external
+     * client would see and keeps the signer/verifier keys
+     * independent (no shared mutable C state). */
+    verifyKey := &gowolf.Ed25519_key{}
+    if rc := gowolf.Wc_ed25519_init(verifyKey); rc != 0 {
+        t.Fatalf("Wc_ed25519_init (verifier): %d", rc)
+    }
+    t.Cleanup(func() { gowolf.Wc_ed25519_free(verifyKey) })
+    if rc := gowolf.Wc_ed25519_import_public(pub, len(pub),
+        verifyKey); rc != 0 {
+        t.Fatalf("Wc_ed25519_import_public: %d", rc)
+    }
+
+    sign := func(challenge []byte) ([]byte, error) {
+        sig := make([]byte, 64)
+        sigLen := 64
+        if rc := gowolf.Wc_ed25519_sign_msg(challenge,
+            len(challenge), sig, &sigLen,
+            &signerKey); rc != 0 {
+            return nil, &agentSignErr{rc: rc}
+        }
+        return sig[:sigLen], nil
+    }
+    return pub, sign, &ed25519Verifier{key: verifyKey}
+}
+
+/*
+ * agentSignErr lets the AgentSigner closure surface a numeric
+ * wolfCrypt return code as a Go error without dragging in
+ * fmt.
+ */
+type agentSignErr struct{ rc int }
+
+func (e *agentSignErr) Error() string {
+    return "wolfssh: agent: Wc_ed25519_sign_msg rc=" +
+        itoa(e.rc)
+}
+
+/*
+ * itoa is a fmt-free decimal integer formatter used by the
+ * one error path that needs it. Keeps the test surface free
+ * of fmt imports for a wrapper file that otherwise wouldn't
+ * need them.
+ */
+func itoa(n int) string {
+    if n == 0 {
+        return "0"
+    }
+    neg := false
+    if n < 0 {
+        neg = true
+        n = -n
+    }
+    var buf [16]byte
+    i := len(buf)
+    for n > 0 {
+        i--
+        buf[i] = byte('0' + n%10)
+        n /= 10
+    }
+    if neg {
+        i--
+        buf[i] = '-'
+    }
+    return string(buf[i:])
+}
+
+/*
+ * min returns the smaller of two ints. Go 1.21+ has a built-in,
+ * but go-wolfssl still builds against older toolchains in CI;
+ * a local copy keeps the test portable.
+ */
+func min(a, b int) int {
+    if a < b {
+        return a
+    }
+    return b
+}
