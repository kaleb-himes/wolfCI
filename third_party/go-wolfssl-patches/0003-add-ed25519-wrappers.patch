+import "C"
+
+import (
+    "unsafe"
+)
+
+type Ed25519_key = C.struct_ed25519_key
+
+func Wc_ed25519_init(key *C.struct_ed25519_key) int {
+    return int(C.wc_ed25519_init(key))
+}
+
+func Wc_ed25519_free(key *C.struct_ed25519_key) {
+    C.wc_ed25519_free(key)
+}
+
+func Wc_ed25519_make_key(rng *C.struct_WC_RNG, keySize int,
+    key *C.struct_ed25519_key) int {
+    return int(C.wc_ed25519_make_key(rng, C.int(keySize), key))
+}
+
+func Wc_ed25519_import_public(in []byte, inLen int,
+    key *C.struct_ed25519_key) int {
+    if inLen == 0 {
+        return BAD_FUNC_ARG
+    }
+    return int(C.wc_ed25519_import_public(
+        (*C.byte)(unsafe.Pointer(&in[0])),
+        C.word32(inLen),
+        key))
+}
+
+func Wc_ed25519_import_private_key(priv []byte, privSz int,
+    pub []byte, pubSz int, key *C.struct_ed25519_key) int {
+    if privSz == 0 || pubSz == 0 {
+        return BAD_FUNC_ARG
+    }
+    return int(C.wc_ed25519_import_private_key(
+        (*C.byte)(unsafe.Pointer(&priv[0])), C.word32(privSz),
+        (*C.byte)(unsafe.Pointer(&pub[0])), C.word32(pubSz),
+        key))
+}
+
+func Wc_ed25519_export_public(key *C.struct_ed25519_key,
+    out []byte, outLen *int) int {
+    if len(out) == 0 || outLen == nil {
+        return BAD_FUNC_ARG
+    }
+    cOutLen := C.word32(*outLen)
+    rc := int(C.wc_ed25519_export_public(
+        key,
+        (*C.byte)(unsafe.Pointer(&out[0])),
+        &cOutLen))
+    *outLen = int(cOutLen)
+    return rc
+}
+
+func Wc_ed25519_export_private_only(key *C.struct_ed25519_key,
+    out []byte, outLen *int) int {
+    if len(out) == 0 || outLen == nil {
+        return BAD_FUNC_ARG
+    }
+    cOutLen := C.word32(*outLen)
+    rc := int(C.wc_ed25519_export_private_only(
+        key,
+        (*C.byte)(unsafe.Pointer(&out[0])),
+        &cOutLen))
+    *outLen = int(cOutLen)
+    return rc
+}
+
+func Wc_ed25519_sign_msg(in []byte, inLen int, out []byte,
+    outLen *int, key *C.struct_ed25519_key) int {
+    if len(out) == 0 || outLen == nil {
+        return BAD_FUNC_ARG
+    }
+    var inPtr *C.byte
+    if inLen > 0 {
+        inPtr = (*C.byte)(unsafe.Pointer(&in[0]))
+    }
+    cOutLen := C.word32(*outLen)
+    rc := int(C.wc_ed25519_sign_msg(
+        inPtr, C.word32(inLen),
+        (*C.byte)(unsafe.Pointer(&out[0])), &cOutLen,
+        key))
+    *outLen = int(cOutLen)
+    return rc
+}
+
+func Wc_ed25519_verify_msg(sig []byte, sigLen int, msg []byte,
+    msgLen int, res *int, key *C.struct_ed25519_key) int {
+    if sigLen == 0 || res == nil {
+        return BAD_FUNC_ARG
+    }
+    var msgPtr *C.byte
+    if msgLen > 0 {
+        msgPtr = (*C.byte)(unsafe.Pointer(&msg[0]))
+    }
+    cRes := C.int(0)
+    rc := int(C.wc_ed25519_verify_msg(
+        (*C.byte)(unsafe.Pointer(&sig[0])), C.word32(sigLen),
+        msgPtr, C.word32(msgLen),
+        &cRes, key))
+    *res = int(cRes)
+    return rc
+}
