+//
+// // Copy a pre-encoded SubjectAltName extension body
+// // (SEQUENCE OF GeneralName, without the outer extension
+// // wrapper) directly into Cert.altNames. Returns 0 on success
+// // or -1 if the input would not fit in the fixed-size buffer.
+// // Requires WOLFSSL_ALT_NAMES.
+// #ifdef WOLFSSL_ALT_NAMES
+// static int wolfci_cert_set_altnames(Cert* cert, const byte* der,
+//         int derSz)
+// {
+//     if (derSz < 0 || (word32)derSz > CTC_MAX_ALT_SIZE) {
+//         return -1;
+//     }
+//     XMEMCPY(cert->altNames, der, derSz);
+//     cert->altNamesSz = derSz;
+//     return 0;
+// }
+// #else
+// static int wolfci_cert_set_altnames(Cert* cert, const byte* der,
+//         int derSz)
+// {
+//     (void)cert;
+//     (void)der;
+//     (void)derSz;
+//     return -1;
+// }
+// #endif
+import "C"
+
+import (
+    "unsafe"
+)
+
+type Cert = C.struct_Cert
+
+const (
+    CTC_SHA256wECDSA = int(C.CTC_SHA256wECDSA)
+    CTC_SHA256wRSA   = int(C.CTC_SHA256wRSA)
+)
+
+func Wc_InitCert(cert *C.struct_Cert) int {
+    return int(C.wc_InitCert(cert))
+}
+
+/*
+ * Wc_SetSubjectCN_Org copies the CommonName + Organization strings
+ * into Cert.subject's fixed-size char arrays. Empty strings leave
+ * the corresponding field untouched.
+ */
+func Wc_SetSubjectCN_Org(cert *C.struct_Cert,
+    commonName, organization string) {
+    cn := C.CString(commonName)
+    defer C.free(unsafe.Pointer(cn))
+    org := C.CString(organization)
+    defer C.free(unsafe.Pointer(org))
+    C.wolfci_cert_set_subject_cn_org(cert, cn, org)
+}
+
+/*
+ * Wc_SetCertValidity sets Cert.daysValid, Cert.isCA, and
+ * Cert.sigType. sigType is one of the CTC_* constants.
+ */
+func Wc_SetCertValidity(cert *C.struct_Cert, daysValid int,
+    isCA bool, sigType int) {
+    ca := 0
+    if isCA {
+        ca = 1
+    }
+    C.wolfci_cert_set_validity(cert, C.int(daysValid), C.int(ca),
+        C.int(sigType))
+}
+
+func Wc_SetIssuerBuffer(cert *C.struct_Cert, der []byte,
+    derSz int) int {
+    if derSz == 0 {
+        return BAD_FUNC_ARG
+    }
+    return int(C.wc_SetIssuerBuffer(
+        cert,
+        (*C.byte)(unsafe.Pointer(&der[0])), C.int(derSz)))
+}
+
+func Wc_SetExtKeyUsage(cert *C.struct_Cert, value string) int {
+    cv := C.CString(value)
+    defer C.free(unsafe.Pointer(cv))
+    return int(C.wc_SetExtKeyUsage(cert, cv))
+}
+
+/*
+ * Wc_SetAltNamesBuffer copies a pre-encoded SubjectAltName
+ * extension body (SEQUENCE OF GeneralName, no outer extension
+ * wrapper) into Cert.altNames. The C-side helper does a memcpy
+ * and sets altNamesSz; the bundled wc_SetAltNamesBuffer
+ * function in wolfSSL itself parses a FULL certificate DER to
+ * extract the altNames, which is the wrong shape for this
+ * use case.
+ *
+ * Requires the wolfSSL build to have WOLFSSL_ALT_NAMES defined;
+ * scripts/build-wolfssl.sh passes that via CPPFLAGS.
+ */
+func Wc_SetAltNamesBuffer(cert *C.struct_Cert, der []byte,
+    derSz int) int {
+    if derSz == 0 {
+        return BAD_FUNC_ARG
+    }
+    return int(C.wolfci_cert_set_altnames(
+        cert,
+        (*C.byte)(unsafe.Pointer(&der[0])), C.int(derSz)))
+}
+
+/*
+ * Wc_MakeCert builds an unsigned X.509 cert in der using the
+ * provided subject key. Exactly one of rsaKey / eccKey must be
+ * non-nil; the other is the placeholder pointer wolfCrypt uses
+ * to determine the subject key type.
+ */
+func Wc_MakeCert(cert *C.struct_Cert, der []byte, derSz int,
+    rsaKey *C.struct_RsaKey, eccKey *C.struct_ecc_key,
+    rng *C.struct_WC_RNG) int {
+    if derSz == 0 {
+        return BAD_FUNC_ARG
+    }
+    return int(C.wc_MakeCert(
+        cert,
+        (*C.byte)(unsafe.Pointer(&der[0])), C.word32(derSz),
+        rsaKey, eccKey, rng))
+}
+
+/*
+ * Wc_SignCert signs the cert body produced by Wc_MakeCert.
+ * requestSz is the body size wc_MakeCert returned. sigType is
+ * one of the CTC_* constants. Exactly one of rsaKey / eccKey
+ * must be non-nil and identifies the signing key.
+ */
+func Wc_SignCert(requestSz int, sigType int,
+    der []byte, derSz int,
+    rsaKey *C.struct_RsaKey, eccKey *C.struct_ecc_key,
+    rng *C.struct_WC_RNG) int {
+    if derSz == 0 {
+        return BAD_FUNC_ARG
+    }
+    return int(C.wc_SignCert(
+        C.int(requestSz), C.int(sigType),
+        (*C.byte)(unsafe.Pointer(&der[0])), C.word32(derSz),
+        rsaKey, eccKey, rng))
+}
